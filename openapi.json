{
  "openapi": "3.0.3",
  "info": {
    "title": "Suki-Link API",
    "description": "短链接服务 API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "本地开发"
    }
  ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": ["认证"],
        "summary": "登录获取Token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": {
                    "type": "string",
                    "example": "12345678"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer", "example": 200 },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": { "type": "string" }
                      }
                    },
                    "message": { "type": "string", "example": "登录成功" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/verify": {
      "get": {
        "tags": ["认证"],
        "summary": "验证Token",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "成功"
          }
        }
      }
    },
    "/api/links": {
      "get": {
        "tags": ["短链管理"],
        "summary": "短链列表",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "cursor",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": ["newest", "oldest", "az", "za"],
              "default": "newest"
            }
          }
        ],
        "responses": {
          "200": { "description": "成功" }
        }
      },
      "post": {
        "tags": ["短链管理"],
        "summary": "创建短链",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url"],
                "properties": {
                  "url": { "type": "string", "example": "https://example.com" },
                  "slug": { "type": "string", "example": "my-link" },
                  "comment": { "type": "string" },
                  "expiration": { "type": "integer", "description": "过期时间戳(秒)" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "创建成功" }
        }
      }
    },
    "/api/links/{slug}": {
      "get": {
        "tags": ["短链管理"],
        "summary": "查询单个短链",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "成功" }
        }
      },
      "put": {
        "tags": ["短链管理"],
        "summary": "编辑短链",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["url"],
                "properties": {
                  "slug": { "type": "string", "example": "my-link" },
                  "url": { "type": "string" },
                  "comment": { "type": "string" },
                  "expiration": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "更新成功" }
        }
      },
      "delete": {
        "tags": ["短链管理"],
        "summary": "删除短链",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "删除成功" }
        }
      }
    },
    "/api/links/export": {
      "get": {
        "tags": ["短链管理"],
        "summary": "导出所有短链",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "cursor",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "description": "成功" }
        }
      }
    },
    "/api/links/import": {
      "post": {
        "tags": ["短链管理"],
        "summary": "批量导入短链",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["version", "links"],
                "properties": {
                  "version": { "type": "string", "example": "1.0" },
                  "links": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "required": ["url"],
                      "properties": {
                        "url": { "type": "string" },
                        "slug": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "导入完成" }
        }
      }
    },
    "/api/links/{slug}/verify-password": {
      "post": {
        "tags": ["短链管理"],
        "summary": "验证短链访问密码",
        "security": [],
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "password": { "type": "string" },
                  "query": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "验证成功" },
          "401": { "description": "密码错误" },
          "404": { "description": "未找到短链" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
